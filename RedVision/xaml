<Window x:Class="RedVision.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RedVision"
        mc:Ignorable="d"
        Title="RedVision" Height="400" Width="360"
        Background="#1C1C1C" Foreground="White" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid x:Name="MainPanel" Visibility="Visible" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <TextBlock Text="RedVision" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="18" Width="35" Height="35" 
                        HorizontalAlignment="Right" Cursor="Hand" Click="BtnSettings_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#33FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Ellipse x:Name="StateDot" Width="10" Height="10" Fill="#FF3B30" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtStatus" Text="Red" Foreground="#AAAAAA" FontSize="13"/>
                </StackPanel>

                <ToggleButton x:Name="BtnToggleRed" Click="BtnToggleRed_Click" Cursor="Hand" Width="180" Height="180">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="BtnBorder" Background="#2D2D2D" CornerRadius="90" BorderBrush="#3D3D3D" BorderThickness="2">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="BtnIcon" Text="👁️" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="BtnText" Text="AKTIVOVAT" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#CC0000"/>
                                    <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#FF453A"/>
                                    <Setter TargetName="BtnText" Property="Text" Value="DEAKTIVOVAT"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
            </StackPanel>

            <TextBlock Grid.Row="2" Text="Aplikace běží na pozadí v systémové liště." 
                       Foreground="#666666" FontSize="11" TextAlignment="Center"/>
        </Grid>

        <Grid x:Name="SettingsPanel" Visibility="Collapsed" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <Button Content="⬅ Zpět" FontSize="13" Foreground="#007AFF" Cursor="Hand" Click="BtnBack_Click" Background="Transparent" BorderBrush="Transparent"/>
                <TextBlock Text="Nastavení" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </DockPanel>

            <StackPanel Grid.Row="1">

                <Border Background="#252525" CornerRadius="8" Padding="15" BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Globální klávesová zkratka" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <WrapPanel Margin="0,0,0,12">
                            <CheckBox x:Name="ChkCtrl" Content="Ctrl" Foreground="White" IsChecked="True" Margin="0,0,15,0" Checked="HotkeyChanged" Unchecked="HotkeyChanged"/>
                            <CheckBox x:Name="ChkAlt" Content="Alt" Foreground="White" IsChecked="True" Margin="0,0,15,0" Checked="HotkeyChanged" Unchecked="HotkeyChanged"/>
                            <CheckBox x:Name="ChkShift" Content="Shift" Foreground="White" Checked="HotkeyChanged" Unchecked="HotkeyChanged"/>
                        </WrapPanel>

                        <DockPanel>
                            <TextBlock Text="Aktivační klávesa:" VerticalAlignment="Center" Foreground="#AAAAAA"/>

                            <TextBox x:Name="TxtKey" Text="R" Height="28" Width="40" HorizontalAlignment="Right" 
                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center" 
                                     Background="#1C1C1C" Foreground="White" BorderBrush="#3D3D3D" BorderThickness="1" 
                                     TextChanged="TxtKey_TextChanged" MaxLength="1" CharacterCasing="Upper"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Background="#252525" CornerRadius="8" Padding="15" BorderBrush="#333333" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="O aplikaci RedVision" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Verze 1.2.0 (Pro)" Foreground="#666666" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>

                            <Button x:Name="BtnUpdate" Content="⬇" ToolTip="Zkontrolovat aktualizace"
                                    Background="#787878" Foreground="White" FontSize="16"
                                    Height="28" Width="35" Cursor="Hand" Click="BtnUpdate_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="Chrání vaše oči a noční vidění odfiltrováním modrého a zeleného spektra na systémové úrovni." 
                                   Foreground="#AAAAAA" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </Grid>
</Window>
