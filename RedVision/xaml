<Window x:Class="RedVision.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RedVision" Height="500" Width="400"
        Background="#181818" Foreground="White" ResizeMode="NoResize" 
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" Background="#444444" CornerRadius="4" Margin="2,0,0,0"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#666666"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#181818" CornerRadius="12" BorderBrush="#2D2D2D" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0" Background="Transparent">
                <Button x:Name="BtnClose" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" 
                        Foreground="#888888" FontSize="11" Width="45" Height="40" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Cursor="Hand" Click="BtnClose_Click" Background="Transparent" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="0,11,0,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- CONTENT -->
            <Grid Grid.Row="1" Margin="25,0,25,25">

                <!-- MAIN PANEL -->
                <Grid x:Name="MainPanel" Visibility="Visible" Opacity="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <TextBlock Text="RedVision" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Foreground="#EEEEEE"/>
                        <Button Content="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="#BBBBBB" FontSize="18" Width="35" Height="35" 
                                HorizontalAlignment="Right" Cursor="Hand" Click="BtnSettings_Click" Background="Transparent" BorderThickness="0" ToolTip="Settings">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DockPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                            <Ellipse x:Name="StateDot" Width="12" Height="12" Fill="#FF3B30" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtStatus" Text="Red Mode disabled" Foreground="#AAAAAA" FontSize="14" FontWeight="Medium"/>
                        </StackPanel>

                        <!-- ANIMATED TOGGLE -->
                        <ToggleButton x:Name="BtnToggleRed" Click="BtnToggleRed_Click" Cursor="Hand" Width="180" Height="180">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="BtnBorder" CornerRadius="90" BorderThickness="3">
                                        <Border.Background>
                                            <SolidColorBrush Color="#222222"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#333333"/>
                                        </Border.BorderBrush>
                                        <Border.Effect>
                                            <DropShadowEffect x:Name="Glow" Color="#FF453A" BlurRadius="0" ShadowDepth="0" Opacity="0" />
                                        </Border.Effect>

                                        <Grid>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock x:Name="BtnIcon" Text="👁️" FontSize="42" HorizontalAlignment="Center" Margin="0,0,0,10" RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                <TextBlock x:Name="TxtMainBtn" Text="ACTIVATE" FontSize="15" FontWeight="Bold" Foreground="#E0E0E0" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <EventTrigger RoutedEvent="ToggleButton.Checked">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#B20000" Duration="0:0:0.3"/>
                                                    <ColorAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#FF453A" Duration="0:0:0.3"/>
                                                    <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="BlurRadius" To="25" Duration="0:0:0.3"/>
                                                    <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0.7" Duration="0:0:0.3"/>
                                                    <DoubleAnimation Storyboard.TargetName="BtnIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.15" Duration="0:0:1" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    <DoubleAnimation Storyboard.TargetName="BtnIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.15" Duration="0:0:1" AutoReverse="True" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>

                                        <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#222222" Duration="0:0:0.3"/>
                                                    <ColorAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#333333" Duration="0:0:0.3"/>
                                                    <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="BlurRadius" To="0" Duration="0:0:0.3"/>
                                                    <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
                                                    <DoubleAnimation Storyboard.TargetName="BtnIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.3"/>
                                                    <DoubleAnimation Storyboard.TargetName="BtnIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.3"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>

                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="TxtMainBtn" Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#555555"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                    </StackPanel>

                    <TextBlock x:Name="TxtTrayInfo" Grid.Row="2" Text="Application runs in the background tray." 
                               Foreground="#666666" FontSize="12" TextAlignment="Center"/>
                </Grid>

                <!-- SETTINGS PANEL -->
                <Grid x:Name="SettingsPanel" Visibility="Collapsed" Opacity="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,15">
                        <Button x:Name="BtnBack" Content="⬅ Back" FontSize="14" FontWeight="Medium" Foreground="#BBBBBB" 
                                Height="35" Cursor="Hand" Click="BtnBack_Click" Background="Transparent" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="8" Padding="10,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock x:Name="TxtSettingsTitle" Text="Settings" FontSize="20" FontWeight="Bold" Foreground="#EEEEEE" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,-15,0" Padding="0,0,10,0">
                        <StackPanel>

                            <!-- LANGUAGE & STARTUP -->
                            <Border Background="#222222" CornerRadius="10" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock x:Name="TxtDisplayCategory" Text="Interface &amp; Display" FontSize="13" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,12"/>

                                    <DockPanel Margin="0,0,0,12">
                                        <TextBlock x:Name="TxtLangLabel" Text="Language:" VerticalAlignment="Center" Foreground="#CCCCCC"/>
                                        <ComboBox x:Name="CmbLang" Height="26" Width="110" HorizontalAlignment="Right" SelectionChanged="CmbLang_SelectionChanged">
                                            <ComboBoxItem Content="English" Tag="EN" IsSelected="True"/>
                                            <ComboBoxItem Content="Čeština" Tag="CS"/>
                                            <ComboBoxItem Content="Deutsch" Tag="DE"/>
                                            <ComboBoxItem Content="Français" Tag="FR"/>
                                            <ComboBoxItem Content="Español" Tag="ES"/>
                                            <ComboBoxItem Content="Italiano" Tag="IT"/>
                                            <ComboBoxItem Content="Português" Tag="PT"/>
                                            <ComboBoxItem Content="Русский" Tag="RU"/>
                                            <ComboBoxItem Content="日本語" Tag="JA"/>
                                            <ComboBoxItem Content="中文(简体)" Tag="ZH"/>
                                            <ComboBoxItem Content="한국어" Tag="KO"/>
                                            <ComboBoxItem Content="العربية" Tag="AR"/>
                                            <ComboBoxItem Content="हिन्दी" Tag="HI"/>
                                        </ComboBox>
                                    </DockPanel>

                                    <CheckBox x:Name="ChkStartup" Content="Run at Windows startup" Foreground="#CCCCCC" IsChecked="False" Checked="ChkStartup_Changed" Unchecked="ChkStartup_Changed"/>
                                </StackPanel>
                            </Border>

                            <!-- HOTKEY -->
                            <Border Background="#222222" CornerRadius="10" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock x:Name="TxtHotkeyCategory" Text="Global Hotkey" FontSize="13" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,12"/>

                                    <WrapPanel Margin="0,0,0,12">
                                        <CheckBox x:Name="ChkCtrl" Content="Ctrl" Foreground="#CCCCCC" IsChecked="True" Margin="0,0,15,0" Checked="HotkeyChanged" Unchecked="HotkeyChanged"/>
                                        <CheckBox x:Name="ChkAlt" Content="Alt" Foreground="#CCCCCC" IsChecked="True" Margin="0,0,15,0" Checked="HotkeyChanged" Unchecked="HotkeyChanged"/>
                                        <CheckBox x:Name="ChkShift" Content="Shift" Foreground="#CCCCCC" Checked="HotkeyChanged" Unchecked="HotkeyChanged"/>
                                    </WrapPanel>

                                    <DockPanel>
                                        <TextBlock x:Name="TxtKeyLabel" Text="Activation Key:" VerticalAlignment="Center" Foreground="#CCCCCC"/>
                                        <TextBox x:Name="TxtKey" Text="R" Height="28" Width="40" HorizontalAlignment="Right" 
                                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontWeight="Bold"
                                                 Background="#181818" Foreground="White" BorderBrush="#444444" BorderThickness="1" 
                                                 TextChanged="TxtKey_TextChanged" MaxLength="1" CharacterCasing="Upper" LostFocus="TxtKey_LostFocus"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <!-- ABOUT & STATS -->
                            <Border Background="#222222" CornerRadius="10" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1" Margin="0,0,10,15">
                                <StackPanel>
                                    <TextBlock Text="RedVision Pro" FontSize="14" FontWeight="Bold" Foreground="#EEEEEE" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="TxtStats" Foreground="#666666" FontSize="12" Margin="0,0,0,12"/>

                                    <Button x:Name="BtnUpdate" Content="⬇ Up to date" ToolTip="Check for updates"
                                            Background="#444444" Foreground="White" FontWeight="SemiBold" FontSize="13"
                                            Height="30" Width="130" HorizontalAlignment="Left" Cursor="Hand" Click="BtnUpdate_Click" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
